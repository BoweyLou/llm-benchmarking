{
  "$schema": "../schemas/area-contracts.schema.json",
  "schema_version": 1,
  "repo_goal": "Maintain a local backend-only LLM benchmarking and model-intelligence workspace that ingests public benchmark data, enriches model metadata, governs commercial/production suitability, and exports auditable SQLite-backed model lists through CLI and FastAPI surfaces.",
  "unknown_policy": "warn",
  "path_contracts": [
    {
      "path": "backend/sources/",
      "purpose": "Benchmark source adapters and raw source parsing for public leaderboard ingestion.",
      "owner": "repo-owner",
      "source": "README.md; UPDATE_GUIDE.md; backend/sources/base.py",
      "status": "aligned",
      "validation": [
        "python -m unittest backend.test_source_spot_checks backend.test_rankings",
        "python -m backend update --benchmarks <adapter-id>"
      ]
    },
    {
      "path": "backend/test_*.py",
      "purpose": "Backend unit, characterization, migration, API, and source-adapter regression tests.",
      "owner": "repo-owner",
      "source": "docs/testing-strategy.md; docs/adr/0001-testing-philosophy.md",
      "status": "aligned",
      "validation": [
        "python -m unittest discover -s backend -t ."
      ]
    },
    {
      "path": "backend/*.json",
      "purpose": "Tracked metadata baselines for provider origin, model curation, and durable license overrides.",
      "owner": "repo-owner",
      "source": "README.md; UPDATE_GUIDE.md",
      "status": "aligned",
      "validation": [
        "python -m backend bootstrap",
        "python -m backend model-card-audit --json"
      ]
    },
    {
      "path": "backend/database.py",
      "purpose": "SQLite schema, migration ledger, views, and database access helpers.",
      "owner": "repo-owner",
      "source": "README.md#schema-migrations; docs/testing-strategy.md",
      "status": "aligned",
      "validation": [
        "python -m unittest backend.test_database_migrations",
        "python -m backend bootstrap"
      ]
    },
    {
      "path": "backend/models.py",
      "purpose": "API response/request models and serialized data contracts.",
      "owner": "repo-owner",
      "source": "README.md; docs/documentation-contract.md",
      "status": "aligned",
      "validation": [
        "python -m unittest backend.test_api_auth backend.test_catalog_export backend.test_rankings"
      ]
    },
    {
      "path": "backend/",
      "purpose": "Backend CLI, FastAPI app, update orchestration, metadata enrichment, ranking, audit, inference, and export code.",
      "owner": "repo-owner",
      "source": "README.md; UPDATE_GUIDE.md; docs/testing-strategy.md",
      "status": "aligned",
      "validation": [
        "python -m py_compile backend/*.py backend/sources/*.py",
        "python -m unittest discover -s backend -t .",
        "python -m backend list-models --output /tmp/llm-benchmarking-models.json"
      ]
    },
    {
      "path": "scripts/",
      "purpose": "Local automation for docs gates, kit workflow checks, task lifecycle, versioning, inference smoke tests, and review helpers.",
      "owner": "repo-owner",
      "source": "AGENTS.md; docs/ops/agent-workflow.md; README.md#contributor-workflow",
      "status": "aligned",
      "validation": [
        "python -m py_compile scripts/*.py",
        "make docs-check",
        "PYTHON=python ./scripts/test_inference_suite.sh"
      ]
    },
    {
      "path": "schemas/",
      "purpose": "JSON schemas for area contracts, task packets, receipts, review artifacts, and research artifacts.",
      "owner": "repo-owner",
      "source": "docs/harness-engineering.md; docs/ops/agent-workflow.md",
      "status": "aligned",
      "validation": [
        "make docs-check",
        "make agent-verify"
      ]
    },
    {
      "path": "docs/",
      "purpose": "Repository documentation, runbooks, decisions, and operator-facing guidance.",
      "owner": "repo-owner",
      "source": "AGENTS.md; REVIEW.md; docs/documentation-contract.md",
      "status": "aligned",
      "validation": [
        "make docs-check"
      ]
    },
    {
      "path": ".agent-workflows/",
      "purpose": "Local agent workflow policy, task metadata, run packets, and workflow state.",
      "owner": "repo-owner",
      "source": "docs/ops/agent-workflow.md",
      "status": "aligned",
      "validation": [
        "make agent-task-status",
        "make goal-check"
      ]
    },
    {
      "path": ".codex/prompts/",
      "purpose": "Repo-local prompt, persona, policy, TDD, and template copies used by Codex workflows.",
      "owner": "repo-owner",
      "source": "AGENTS.md; docs/ops/agent-workflow.md",
      "status": "aligned",
      "validation": [
        "make agent-docs-lint",
        "make docs-check"
      ]
    },
    {
      "path": ".doc-contract-kit/",
      "purpose": "Repo-contract-kit managed manifests, make fragments, receipts, and update proposals.",
      "owner": "repo-owner",
      "source": "AGENTS.md; docs/upgrade-flow.md",
      "status": "aligned",
      "validation": [
        "make kit-status",
        "make docs-check"
      ]
    },
    {
      "path": ".github/",
      "purpose": "GitHub workflow files, issue/PR templates, and repository automation metadata.",
      "owner": "repo-owner",
      "source": "AGENTS.md; docs/documentation-contract.md",
      "status": "aligned",
      "validation": [
        "make docs-check",
        "make version-check"
      ]
    },
    {
      "path": ".gitignore",
      "purpose": "Repository ignore policy for generated data, caches, local runtime artifacts, and disposable outputs.",
      "owner": "repo-owner",
      "source": "AGENTS.md; docs/documentation-contract.md",
      "status": "aligned",
      "validation": [
        "git status --short",
        "make docs-check"
      ]
    },
    {
      "path": ".pre-commit-config.yaml",
      "purpose": "Local pre-commit hook configuration for repository validation before commits.",
      "owner": "repo-owner",
      "source": "AGENTS.md; .pre-commit-config.yaml",
      "status": "aligned",
      "validation": [
        "pre-commit run --all-files",
        "make docs-check"
      ]
    },
    {
      "path": "*.md",
      "purpose": "Root-level project docs, review notes, build specs, and generated benchmark report artifacts.",
      "owner": "repo-owner",
      "source": "docs/documentation-contract.md",
      "status": "aligned",
      "validation": [
        "make docs-check"
      ]
    },
    {
      "path": "Makefile",
      "purpose": "Repository workflow entrypoints for docs, kit, task lifecycle, version, and validation gates.",
      "owner": "repo-owner",
      "source": "AGENTS.md; docs/ops/agent-workflow.md",
      "status": "aligned",
      "validation": [
        "make docs-check",
        "make kit-status"
      ]
    },
    {
      "path": "doc-contract.json",
      "purpose": "Repository-specific documentation impact rules and docs-as-code contract metadata.",
      "owner": "repo-owner",
      "source": "docs/documentation-contract.md",
      "status": "aligned",
      "validation": [
        "python3 scripts/check_doc_impact.py",
        "make docs-check"
      ]
    },
    {
      "path": "VERSION",
      "purpose": "Local SemVer source of truth for release-impacting changes.",
      "owner": "repo-owner",
      "source": "docs/versioning.md; AGENTS.md",
      "status": "aligned",
      "validation": [
        "make version-check"
      ]
    },
    {
      "path": "CHANGELOG.md",
      "purpose": "Human-readable release history tied to VERSION changes.",
      "owner": "repo-owner",
      "source": "docs/versioning.md; AGENTS.md",
      "status": "aligned",
      "validation": [
        "make version-check",
        "make docs-check"
      ]
    },
    {
      "path": "LICENSE",
      "purpose": "Repository licensing metadata.",
      "owner": "repo-owner",
      "source": "README.md; docs/documentation-contract.md",
      "status": "aligned",
      "validation": [
        "make docs-check"
      ]
    }
  ]
}
