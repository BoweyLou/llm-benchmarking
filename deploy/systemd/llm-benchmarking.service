[Unit]
Description=LLM Benchmarking banking review workbench
After=network-online.target tailscaled.service
Wants=network-online.target

[Service]
Type=simple
User=llm-benchmarking
Group=llm-benchmarking
WorkingDirectory=/opt/llm-benchmarking/current
EnvironmentFile=/etc/llm-benchmarking.env
ExecStart=/bin/sh -c 'exec /opt/llm-benchmarking/current/.venv/bin/uvicorn backend.main:app --host "$LLM_BENCHMARKING_HOST" --port "$LLM_BENCHMARKING_PORT"'
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/var/lib/llm-benchmarking
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
CapabilityBoundingSet=
UMask=0077

[Install]
WantedBy=multi-user.target
