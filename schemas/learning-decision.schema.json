{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/repo-contract-kit/learning-decision.schema.json",
  "title": "Supervised Learning Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision_id",
    "decided_at",
    "policy_id",
    "repo",
    "proposal_id",
    "outcome",
    "rationale",
    "decider",
    "human_review",
    "lineage",
    "privacy_label",
    "follow_up",
    "non_execution_guarantee"
  ],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "decision_id": {"type": "string", "pattern": "^dec-[0-9a-f]{20}$"},
    "decided_at": {"type": "string", "format": "date-time"},
    "policy_id": {"type": "string", "const": "supervised-learning"},
    "repo": {"type": "string", "minLength": 1},
    "proposal_id": {"type": "string", "pattern": "^prop-[0-9a-f]{20}$"},
    "outcome": {"type": "string", "enum": ["approved", "rejected", "deferred"]},
    "rationale": {"type": "string", "minLength": 1, "maxLength": 500},
    "decider": {"type": "string", "minLength": 1, "maxLength": 120},
    "human_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "confirmed", "capture"],
      "properties": {
        "required": {"type": "boolean", "const": true},
        "confirmed": {"type": "boolean", "const": true},
        "capture": {"type": "string", "const": "explicit-cli-input"}
      }
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proposal_id", "evidence_event_ids"],
      "properties": {
        "proposal_id": {"type": "string", "pattern": "^prop-[0-9a-f]{20}$"},
        "evidence_event_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10,
          "items": {"type": "string", "pattern": "^evt-[0-9a-f]{20}$"}
        }
      }
    },
    "privacy_label": {"type": "string", "enum": ["public-ok", "internal", "private-local", "sensitive-local"]},
    "follow_up": {
      "type": "array",
      "maxItems": 10,
      "items": {"type": "string", "minLength": 1, "maxLength": 500}
    },
    "non_execution_guarantee": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enforced", "recommendation_execution_permitted", "prohibited_writes", "note"],
      "properties": {
        "enforced": {"type": "boolean", "const": true},
        "recommendation_execution_permitted": {"type": "boolean", "const": false},
        "prohibited_writes": {
          "type": "array",
          "const": ["AGENTS.md", "policy files", "target files", "global tool state"]
        },
        "note": {
          "type": "string",
          "const": "An approved proposal or decision records a review outcome only. It is not permission to write AGENTS.md, policy files, target files, or global tool state, and Kit will not execute the recommendation."
        }
      }
    }
  }
}
