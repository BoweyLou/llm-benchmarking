{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/repo-contract-kit/learning-event.schema.json",
  "title": "Supervised Learning Event",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "event_id", "occurred_at", "policy_id", "repo", "kind", "summary", "evidence", "outcome", "provenance", "privacy_label", "supervision"],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "event_id": {"type": "string", "pattern": "^evt-[0-9a-f]{20}$"},
    "occurred_at": {"type": "string", "format": "date-time"},
    "policy_id": {"type": "string", "const": "supervised-learning"},
    "repo": {"type": "string", "minLength": 1},
    "kind": {"type": "string", "enum": ["observation", "validation", "feedback", "incident"]},
    "summary": {"type": "string", "minLength": 1, "maxLength": 500},
    "evidence": {
      "type": "array",
      "maxItems": 10,
      "items": {"type": "string", "minLength": 1, "maxLength": 500}
    },
    "outcome": {"type": "string", "enum": ["confirmed", "inconclusive", "regressed", "unknown"]},
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "capture"],
      "properties": {
        "source": {"type": "string", "enum": ["human", "agent", "automation"]},
        "capture": {"type": "string", "enum": ["explicit-cli-input", "thread-summary-import"]}
      }
    },
    "privacy_label": {"type": "string", "enum": ["public-ok", "internal", "private-local", "sensitive-local"]},
    "supervision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["human_approval_required", "approval_state", "approval_flag"],
      "properties": {
        "human_approval_required": {"type": "boolean", "const": true},
        "approval_state": {"type": "string", "const": "approved"},
        "approval_flag": {"type": "boolean", "const": true}
      }
    }
  }
}
