{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/repo-contract-kit/learning-proposal.schema.json",
  "title": "Supervised Learning Proposal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "proposal_id",
    "created_at",
    "policy_id",
    "repo",
    "title",
    "classification",
    "scope",
    "recommended_change",
    "lineage",
    "privacy_label",
    "status",
    "human_approval_required",
    "decision_id",
    "non_execution_guarantee"
  ],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "proposal_id": {"type": "string", "pattern": "^prop-[0-9a-f]{20}$"},
    "created_at": {"type": "string", "format": "date-time"},
    "policy_id": {"type": "string", "const": "supervised-learning"},
    "repo": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1, "maxLength": 160},
    "classification": {"type": "string", "enum": ["documentation", "workflow", "policy", "harness", "process", "other"]},
    "scope": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {"type": "string", "minLength": 1, "maxLength": 200}
    },
    "recommended_change": {"type": "string", "minLength": 1, "maxLength": 500},
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_event_ids"],
      "properties": {
        "evidence_event_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^evt-[0-9a-f]{20}$"}
        }
      }
    },
    "privacy_label": {"type": "string", "enum": ["public-ok", "internal", "private-local", "sensitive-local"]},
    "status": {"type": "string", "enum": ["pending-review", "approved", "rejected", "deferred"]},
    "human_approval_required": {"type": "boolean", "const": true},
    "decision_id": {"type": ["string", "null"], "pattern": "^dec-[0-9a-f]{20}$"},
    "non_execution_guarantee": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enforced", "recommendation_execution_permitted", "prohibited_writes", "note"],
      "properties": {
        "enforced": {"type": "boolean", "const": true},
        "recommendation_execution_permitted": {"type": "boolean", "const": false},
        "prohibited_writes": {
          "type": "array",
          "const": ["AGENTS.md", "policy files", "target files", "global tool state"]
        },
        "note": {
          "type": "string",
          "const": "An approved proposal or decision records a review outcome only. It is not permission to write AGENTS.md, policy files, target files, or global tool state, and Kit will not execute the recommendation."
        }
      }
    }
  }
}
