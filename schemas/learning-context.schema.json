{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/repo-contract-kit/learning-context.schema.json",
  "title": "Supervised Learning Context",
  "description": "Bounded sidecar-only guidance constructed only from an approved local decision and its linked valid proposal. Event, evidence, feedback, and conversation content are excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "context_id",
    "captured_at",
    "policy_id",
    "repo",
    "lineage",
    "guidance",
    "privacy_label",
    "retention",
    "sidecar_only_guidance",
    "non_execution_guarantee"
  ],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "context_id": {"type": "string", "pattern": "^ctx-[0-9a-f]{20}$"},
    "captured_at": {"type": "string", "format": "date-time"},
    "policy_id": {"type": "string", "const": "supervised-learning"},
    "repo": {"type": "string", "minLength": 1},
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision_id", "proposal_id"],
      "properties": {
        "decision_id": {"type": "string", "pattern": "^dec-[0-9a-f]{20}$"},
        "proposal_id": {"type": "string", "pattern": "^prop-[0-9a-f]{20}$"}
      }
    },
    "guidance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classification", "scope", "recommended_change"],
      "properties": {
        "classification": {"type": "string", "enum": ["documentation", "workflow", "policy", "harness", "process", "other"]},
        "scope": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10,
          "items": {"type": "string", "minLength": 1, "maxLength": 200}
        },
        "recommended_change": {"type": "string", "minLength": 1, "maxLength": 500}
      }
    },
    "privacy_label": {"type": "string", "enum": ["public-ok", "internal", "private-local", "sensitive-local"]},
    "retention": {
      "type": "object",
      "additionalProperties": false,
      "required": ["days", "expires_at"],
      "properties": {
        "days": {"type": "integer", "minimum": 1},
        "expires_at": {"type": "string", "format": "date-time"}
      }
    },
    "sidecar_only_guidance": {"type": "boolean", "const": true},
    "non_execution_guarantee": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enforced", "recommendation_execution_permitted", "prohibited_writes", "note"],
      "properties": {
        "enforced": {"type": "boolean", "const": true},
        "recommendation_execution_permitted": {"type": "boolean", "const": false},
        "prohibited_writes": {"type": "array", "items": {"type": "string"}},
        "note": {"type": "string", "minLength": 1}
      }
    }
  }
}
